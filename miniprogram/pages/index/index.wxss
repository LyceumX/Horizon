/* pages/index/index.wxss */

.container {
  width: 100vw;
  height: 100vh;
}

.container web-view {
  width: 100%;
  height: 100%;
}

.placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 2rem;
  text-align: center;
}

.placeholder-icon {
  width: 80px;
  height: 80px;
  border-radius: 20px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  font-weight: 600;
  margin-bottom: 1.5rem;
}

.placeholder-title {
  font-size: 20px;
  font-weight: 600;
  color: #333;
  margin-bottom: 0.5rem;
}

.placeholder-desc {
  font-size: 14px;
  color: #999;
  line-height: 1.6;
}
